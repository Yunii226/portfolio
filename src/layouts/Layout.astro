---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang: 'es' | 'en';
}

const { title, description, lang } = Astro.props;

// Absolute URLs for canonical / hreflang / social cards. Astro.site is set in
// astro.config.mjs (https://unaiguerra.dev).
const site = Astro.site ?? new URL('https://unaiguerra.dev');
const canonical = new URL(Astro.url.pathname, site).href;
const esUrl = new URL('/', site).href;
const enUrl = new URL('/en/', site).href;
const ogImage = new URL('/og.png', site).href;

// Person structured data — the single biggest lever for ranking on a name
// query. sameAs ties the page to known profiles so Google resolves the entity.
const person = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Unai Guerra Matas',
  alternateName: 'Unai Guerra',
  url: esUrl,
  image: ogImage,
  jobTitle: lang === 'es' ? 'Desarrollador de Software' : 'Software Developer',
  email: 'mailto:guerramatasunai@gmail.com',
  sameAs: [
    'https://github.com/Yunii226',
    'https://www.linkedin.com/in/unai-guerra-matas-918a87384',
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Unai Guerra Matas" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="profile" />
    <meta property="og:site_name" content="Unai Guerra Matas" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta property="profile:first_name" content="Unai" />
    <meta property="profile:last_name" content="Guerra Matas" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="alternate" hreflang="es" href={esUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={esUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(person)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wdth,wght@62..125,100..900&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;700&family=Press+Start+2P&display=swap"
      rel="stylesheet"
    />
    <!-- Theme before paint: saved choice wins, otherwise system preference -->
    <script is:inline>
      (() => {
        const saved = localStorage.getItem('theme');
        const dark = saved ? saved === 'dark' : matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.classList.toggle('dark', dark);
      })();
    </script>
  </head>
  <body>
    <slot />

    <script>
      // Scroll reveal: .reveal elements slide in once when they enter the viewport.
      const els = document.querySelectorAll<HTMLElement>('.reveal');
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
      );
      els.forEach((el) => io.observe(el));
    </script>
  </body>
</html>
