---
import Layout from '../layouts/Layout.astro';
import AsciiHero from '../components/AsciiHero.astro';
import Experience from '../components/Experience.astro';
import Skills from '../components/Skills.astro';
import Projects from '../components/Projects.astro';
import TechScanner from '../components/TechScanner';

const contactLinks = [
  { label: 'GitHub', value: 'github.com/Yunii226', url: 'https://github.com/Yunii226' },
  { label: 'LinkedIn', value: 'linkedin.com/in/unai-guerra', url: 'https://www.linkedin.com/in/unai-guerra-matas-918a87384' },
  { label: 'Email', value: 'guerramatasunai@gmail.com', url: 'mailto:guerramatasunai@gmail.com' },
];
---

<Layout title="Unai Guerra Matas | Software Developer Portfolio">
  <main>
    <AsciiHero />

    <section id="about" class="py-24 px-4 bg-tech-gray-deep/10 border-y border-tech-gray/20">
      <div class="max-w-5xl mx-auto flex flex-col md:flex-row gap-16 items-center">
        <div class="flex-shrink-0">
          <TechScanner client:load />
        </div>
        <div class="flex-grow">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-2 h-2 bg-tech-silver animate-pulse"></div>
            <h2 class="text-3xl font-bold tech-text-gradient font-mono tracking-tighter">00_INITIALIZATION.SYS</h2>
          </div>
          <p class="text-xl text-tech-silver leading-relaxed font-light">
            Especialista en <span class="text-white font-mono underline decoration-tech-steel underline-offset-4">Desarrollo de Aplicaciones Multiplataforma</span> y <span class="text-white font-mono underline decoration-tech-steel underline-offset-4">Automatización de Procesos</span>. 
            Con experiencia sólida en ecosistemas <span class="text-white">Escritorio</span>, <span class="text-white">Web</span> y <span class="text-white">Móvil (Android/iOS)</span>, mi enfoque integra el desarrollo de software de alto nivel con tecnologías como <span class="text-white">.NET</span> y lenguajes modernos. 
            Actualmente evolucionando hacia la especialización en <span class="text-white font-semibold">Inteligencia Artificial</span>, con un profundo interés en integrar modelos avanzados para potenciar la eficiencia empresarial.
          </p>
          <div class="mt-8 grid grid-cols-2 gap-4 text-xs font-mono text-tech-steel">
            <div class="flex items-center gap-2">
              <span class="text-tech-silver">[√]</span> DESKTOP_WEB_IOS
            </div>
            <div class="flex items-center gap-2">
              <span class="text-tech-silver">[√]</span> AI_INTEGRATION_LAB
            </div>
            <div class="flex items-center gap-2">
              <span class="text-tech-silver">[√]</span> ANDROID_NATIVE
            </div>
            <div class="flex items-center gap-2">
              <span class="text-tech-silver">[√]</span> PROCESS_AUTOMATION
            </div>
          </div>
        </div>
      </div>
    </section>

    <Experience />
    
    <Skills />

    <Projects />

    <footer id="contact" class="py-24 px-4 border-t border-tech-gray bg-tech-black relative overflow-hidden">
      {/* Elemento decorativo ASCII al fondo */}
      <pre class="absolute -bottom-10 -right-10 text-tech-gray/10 text-[150px] pointer-events-none select-none">
        &gt;_
      </pre>

      <div class="max-w-4xl mx-auto text-center relative z-10">
        <h2 class="text-4xl font-bold tech-text-gradient mb-12 tracking-tighter">HANDSHAKE_PROTOCOL</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
          {contactLinks.map((link) => (
            <a href={link.url} target="_blank" class="metallic-card p-8 group hover:border-white/20 transition-all">
              <span class="text-tech-steel font-mono text-xs block mb-2 tracking-[0.2em]">{link.label}</span>
              <span class="text-tech-silver font-bold group-hover:text-white transition-colors">{link.value}</span>
            </a>
          ))}
        </div>

        <div class="text-tech-steel font-mono text-[10px] space-y-2 uppercase tracking-[0.3em]">
          <p>© 2026 UNAI GUERRA MATAS // CORE_SYSTEM_STABLE</p>
          <p>[ POWERED_BY: ASTRO_FRAMEWORK + TAILWIND_ENGINE ]</p>
        </div>
      </div>
    </footer>
  </main>
</Layout>