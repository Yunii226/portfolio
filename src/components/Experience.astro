---
const experiences = [
  {
    date: '03/2026 - 05/2026',
    company: 'AYCE LABORYTAX',
    role: 'Prácticas - Desarrollo de Software',
    description: [
      'Diseño y desarrollo de aplicaciones internas con .NET.',
      'Automatización de tareas recurrentes con Power Automate.',
      'Análisis de requisitos y propuestas de mejora.',
    ],
    tech: ['.NET', 'Power Automate']
  },
  {
    date: '05/2025',
    company: 'Kanzan Tech (OutSystems)',
    role: 'Prácticas - Desarrollo low-code',
    description: [
      'Desarrollo y mantenimiento de aplicaciones con OutSystems.',
      'Trabajo con formularios, lógica y consumo de APIs REST.',
    ],
    tech: ['OutSystems', 'APIs REST']
  }
];
---

<section id="experience" class="py-24 px-4 max-w-4xl mx-auto">
  <div class="flex items-center gap-4 mb-12">
    <h2 class="text-3xl font-bold tech-text-gradient">01_EXPERIENCE.LOG</h2>
    <div class="flex-grow h-[1px] bg-tech-gray"></div>
  </div>

  <div class="space-y-12">
    {experiences.map((exp) => (
      <div class="relative pl-8 border-l border-tech-gray group">
        <div class="absolute -left-[5px] top-0 w-[9px] h-[9px] bg-tech-silver rounded-full group-hover:scale-150 transition-transform"></div>
        
        <div class="metallic-card p-6">
          <div class="flex flex-wrap justify-between items-start gap-2 mb-4">
            <div>
              <h3 class="text-2xl font-bold text-tech-titanium">{exp.company}</h3>
              <p class="text-tech-silver font-mono italic">{exp.role}</p>
            </div>
            <span class="text-tech-steel font-mono text-sm">{exp.date}</span>
          </div>
          
          <ul class="list-none space-y-2 mb-6">
            {exp.description.map((item) => (
              <li class="text-tech-silver/80 flex gap-2">
                <span class="text-tech-steel">»</span> {item}
              </li>
            ))}
          </ul>

          <div class="flex flex-wrap gap-2">
            {exp.tech.map((t) => (
              <span class="px-3 py-1 bg-tech-gray text-tech-silver text-xs font-mono rounded">
                {t}
              </span>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>