---
import type { ImageMetadata } from 'astro';
import { strings, type Lang } from '../i18n/strings';
import ImageSlot from './ImageSlot.astro';
import alexImage from '../assets/Alex.png';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = strings[lang].projects;

// PICTURE GAP #2 — project screenshots. Drop files into src/assets/projects/
// and wire them here by project title.
const covers: Record<string, ImageMetadata | undefined> = {
  'English With Alex': alexImage,
};

const slotAscii = `  ________
 |  ____  |
 | |    | |
 | |____| |
 |________|`;
---

<section id="projects" class="relative py-28 px-4 overflow-hidden">
  <div class="chroma-fog absolute inset-0 pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-6xl mx-auto">
    <div class="reveal">
      <p class="section-tag mb-3">{t.tag}</p>
      <h2 class="rgb-split font-display font-black text-4xl md:text-6xl tracking-tight mb-14 w-fit">{t.title}</h2>
    </div>

    <div class="space-y-10">
      {
        t.entries.map((project, i) => (
          <article
            class="reveal group border border-line bg-card backdrop-blur-sm p-6 md:p-10 grid md:grid-cols-[minmax(0,2fr)_minmax(0,3fr)] gap-8 hover:border-accent/60 hover:-translate-y-1 transition-all duration-300"
            style={`--rd: ${100 + i * 100}ms`}
          >
            <div class="aspect-video border border-line overflow-hidden">
              <ImageSlot
                image={covers[project.title]}
                alt={project.title}
                hint={t.imageHint}
                ascii={slotAscii}
                class="opacity-85 group-hover:opacity-100 group-hover:scale-[1.02] transition-all duration-500"
              />
            </div>

            <div class="flex flex-col justify-between gap-6">
              <div>
                <span class="font-mono text-[10px] tracking-[0.25em] text-muted uppercase">{project.kind}</span>
                <h3 class="chroma-text font-display font-black text-3xl md:text-5xl tracking-tight w-fit mt-2">
                  {project.title}
                </h3>
                <p class="mt-4 opacity-85 text-lg leading-relaxed">{project.description}</p>
                <p class="mt-3 font-serif italic text-lg opacity-85">{project.aside}</p>
              </div>

              <div class="flex flex-wrap items-center justify-between gap-4">
                <div class="flex flex-wrap gap-3 font-mono text-xs text-muted">
                  {project.stack.map((s) => (
                    <span>#{s}</span>
                  ))}
                </div>
                <a
                  href={project.link}
                  target="_blank"
                  rel="noopener"
                  class="font-mono text-sm border border-fg px-5 py-3 hover:bg-accent hover:border-accent hover:text-night transition-colors"
                >
                  {t.repoLabel} ↗
                </a>
              </div>
            </div>
          </article>
        ))
      }

      <!-- reserved slot: future project + its picture gap -->
      <div class="reveal border-2 border-dashed border-line p-10 flex items-center justify-center gap-4 min-h-[140px] text-center" style="--rd: 200ms">
        <span class="font-mono text-xs tracking-[0.15em] text-muted">
          {t.next}<span class="blink text-accent">▮</span>
        </span>
      </div>
    </div>
  </div>
</section>
