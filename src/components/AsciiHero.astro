---
import AnimatedTitle from './AnimatedTitle';
---

<section class="min-h-screen flex flex-col justify-center items-center p-4 relative overflow-hidden">
  {/* Fondo de red metálica */}
  <div class="absolute inset-0 z-0 opacity-10">
    <div class="grid grid-cols-12 h-full w-full">
      {Array.from({ length: 48 }).map((_, i) => (
        <div class="border-[0.5px] border-tech-steel h-full w-full"></div>
      ))}
    </div>
  </div>

  <div class="z-10 text-center">
    <AnimatedTitle client:load />
    
    <div class="space-y-4">
      <h1 class="text-5xl md:text-7xl font-extrabold tech-text-gradient tracking-tighter">
        UNAI GUERRA MATAS
      </h1>
      <div class="flex items-center justify-center gap-4">
        <div class="h-[1px] w-12 bg-tech-steel"></div>
        <p class="text-xl md:text-2xl text-tech-silver font-mono">
          DESARROLLADOR DE SOFTWARE
        </p>
        <div class="h-[1px] w-12 bg-tech-steel"></div>
      </div>
    </div>

    <div class="mt-12 flex flex-wrap justify-center gap-6">
      <a href="#projects" class="group relative px-8 py-3 bg-tech-titanium text-tech-black font-bold rounded-sm overflow-hidden transition-all">
        <span class="relative z-10">VER_PROYECTOS</span>
        <div class="absolute inset-0 bg-white translate-y-full group-hover:translate-y-0 transition-transform"></div>
      </a>
      <a href="#contact" class="px-8 py-3 border border-tech-silver text-tech-silver font-bold rounded-sm hover:bg-tech-silver/10 transition-all font-mono">
        >_CONTACTO
      </a>
    </div>
  </div>

  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce text-tech-steel">
    <pre class="text-[10px] leading-none">
      |
      V
    </pre>
  </div>
</section>